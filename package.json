{
  "name": "@bounded-systems/bd",
  "version": "0.2.0",
  "description": "Typed interface to the beads CLI with policy enforcement and short-ID guards",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/bd.git"
  },
  "homepage": "https://github.com/bounded-systems/bd#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/bd/issues"
  },
  "keywords": [
    "beads",
    "bd",
    "cli-wrapper",
    "policy",
    "issues"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@bounded-systems/env": "workspace:*",
    "@bounded-systems/proc": "workspace:*",
    "@bounded-systems/policy": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  }
}
