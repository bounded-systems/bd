{
  "name": "@bounded-systems/bd",
  "version": "0.2.0",
  "description": "Typed interface to the beads CLI with policy enforcement and short-ID guards",
  "bounded": {
    "tagline": "Typed interface to the beads CLI with policy enforcement and short-ID guards",
    "kind": "door",
    "facet": "verb",
    "role": "client",
    "domain": "beads/tasks"
  },
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bounded-systems/bd.git"
  },
  "homepage": "https://github.com/bounded-systems/bd#readme",
  "bugs": {
    "url": "https://github.com/bounded-systems/bd/issues"
  },
  "keywords": [
    "beads",
    "bd",
    "cli-wrapper",
    "policy",
    "issues"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@bounded-systems/env": "npm:@jsr/bounded-systems__env",
    "@bounded-systems/policy": "npm:@jsr/bounded-systems__policy",
    "@bounded-systems/proc": "npm:@jsr/bounded-systems__proc"
  }
}
